# Copy to .env — never commit .env

# Teacher LLM (Claude/GPT) — required for synthetic data generation
TEACHER_API_KEY=
TEACHER_PROVIDER=anthropic
TEACHER_MODEL=claude-sonnet-4-20250514

# HuggingFace — optional, for downloading student models
HF_TOKEN=

# Data directory override (default: ./data)
NANO_CODER_DATA_DIR=

# Pipeline
APP_ENV=development
LOG_LEVEL=info
MAX_BUDGET_USD=200
