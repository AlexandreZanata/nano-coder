{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nano-coder.local/schemas/gold-seed-v1.json",
  "title": "GoldSeedExample",
  "description": "Manual gold seed for synthetic expansion (GLOSSARY.md, PIPELINE-CONTRACT.md)",
  "type": "object",
  "required": ["id", "targetLanguage", "instruction", "code", "tags"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(seed|REF)-(js|html|fmt)-[0-9]{3}$"
    },
    "targetLanguage": {
      "type": "string",
      "enum": ["JavaScript", "HTML", "FreeMarker"]
    },
    "instruction": {
      "type": "string",
      "minLength": 20
    },
    "code": {
      "type": "string",
      "minLength": 10
    },
    "tags": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "metadata": {
      "type": "object",
      "required": ["author", "created", "source"],
      "additionalProperties": false,
      "properties": {
        "author": { "type": "string", "minLength": 1 },
        "created": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "source": {
          "type": "string",
          "enum": ["manual", "reference", "synthetic"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}
